# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# LLM provider — LiteLLM format: "provider/model"
# Examples:
#   gemini/gemini-2.0-flash       (get key at aistudio.google.com)
#   gemini/gemini-2.5-pro
#   groq/llama-3.3-70b-versatile  (free tier at console.groq.com)
#   openai/gpt-4o
#   anthropic/claude-sonnet-4-6
#   ollama/llama3
LLM_MODEL=gemini/gemini-2.0-flash

# Provider API keys — set the one that matches your LLM_MODEL provider
GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# App
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=./outputs
